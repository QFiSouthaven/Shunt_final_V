# Aether Shunt Management Hub — example env
# Copy to .env.local and fill in the blanks.

# --- Local services (loopback only) ---
# panel-server.mjs serves transcript, inbox, presence, SSE stream
PANEL_SERVER_URL=http://localhost:7777
# orchestrator.mjs serves bridge start/stop/restart and status
ORCHESTRATOR_URL=http://localhost:7778

# --- Cloudflare Worker (hub-relay) — leave blank until deployed ---
WORKER_URL=
# Bearer token for Worker; server-side only, never expose to the client.
HUB_API_SECRET=

# --- Admin identity ---
# Comma-separated JIDs that are granted admin rights when their JID matches
# the request's x-auth-email header (set by middleware from query param or
# HUB_DEV_JID for local dev; Cloudflare Access SSO for production).
HUB_ADMIN_JIDS=@zack
# Local-dev identity. Middleware stamps this as x-auth-email on every request.
# Leave UNSET in any non-loopback deployment.
HUB_DEV_JID=@zack

# --- AI annotation service (server-side, used by /api/ai/annotate) ---
# Hub UI runs server-side env config because Next route handlers cannot
# read the SPA's localStorage across origins. Mirror your LM Studio /
# OpenAI-compatible endpoint here.
HUB_AI_BASE_URL=http://localhost:1234/v1/chat/completions
HUB_AI_MODEL=local-model
HUB_AI_API_KEY=
HUB_AI_TIMEOUT_MS=30000
