@echo off
REM worker-health.bat - Runs three Cloudflare Worker health checks: /healthz (no auth), /presence (no bearer, expect 401), /presence (with bearer).
powershell -NoProfile -ExecutionPolicy Bypass -Command "$workerUrl = 'https://hub-relay.halkive.workers.dev'; Write-Host '--- Check 1: /healthz (no auth required) ---' -ForegroundColor Cyan; try { $r = Invoke-RestMethod ($workerUrl + '/healthz'); Write-Host 'PASS' -ForegroundColor Green; $r | ConvertTo-Json -Compress | Write-Host } catch { Write-Host ('FAIL: ' + $_.Exception.Message) -ForegroundColor Red } ; Write-Host '' ; Write-Host '--- Check 2: /presence (no bearer, expect 401) ---' -ForegroundColor Cyan; try { Invoke-RestMethod ($workerUrl + '/presence') | Out-Null; Write-Host 'FAIL: expected 401 but got 200' -ForegroundColor Red } catch { $code = $_.Exception.Response.StatusCode.value__; if ($code -eq 401) { Write-Host 'PASS: 401 Unauthorized as expected' -ForegroundColor Green } else { Write-Host ('FAIL: got status ' + $code) -ForegroundColor Red } } ; Write-Host '' ; Write-Host '--- Check 3: /presence (with bearer) ---' -ForegroundColor Cyan; if ($env:HUB_API_SECRET) { $token = $env:HUB_API_SECRET; Write-Host 'Using HUB_API_SECRET from environment.' -ForegroundColor Yellow } else { $secure = Read-Host -AsSecureString -Prompt 'Enter HUB_API_SECRET'; $bstr = [System.Runtime.InteropServices.Marshal]::SecureStringToBSTR($secure); $token = [System.Runtime.InteropServices.Marshal]::PtrToStringAuto($bstr); [System.Runtime.InteropServices.Marshal]::ZeroFreeBSTR($bstr) } ; try { $r = Invoke-RestMethod ($workerUrl + '/presence') -Headers @{ Authorization = 'Bearer ' + $token } ; Write-Host 'PASS' -ForegroundColor Green; $r | ConvertTo-Json -Compress | Write-Host } catch { Write-Host ('FAIL: ' + $_.Exception.Message) -ForegroundColor Red }"
echo.
pause
